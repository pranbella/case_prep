# Anthropic API key used for server-side grading (Claude Sonnet).
# Get one at https://console.anthropic.com/
# Copy this file to .env.local and paste your real key there (never commit real keys).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Grading model. Defaults to claude-sonnet-4-5 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-5
